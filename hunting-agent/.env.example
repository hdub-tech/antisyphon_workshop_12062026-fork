# Model names change over time. Use a valid model ID for the selected provider.
# API model catalogs:
# Gemini: https://ai.google.dev/gemini-api/docs/models
# OpenAI: https://developers.openai.com/api/docs/models
# Anthropic: https://platform.claude.com/docs/en/docs/about-claude/models/overview
#
# Important:
# - API providers use API model IDs.
# - CLI providers may also support CLI aliases, e.g. Claude Code accepts "sonnet" and "opus".

LLM_PROVIDER=gemini

GEMINI_API_KEY=paste-your-key-here
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-pro

# ANTHROPIC_API_KEY=paste-your-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OPENAI_API_KEY=paste-your-key-here
# OPENAI_MODEL=gpt-5.4-mini
# OPENAI_MODEL=gpt-5.4
# OPENAI_MODEL=gpt-5.5
#
# --- Advanced / experimental: LOCAL or LAN models (Ollama, LM Studio, llama.cpp, vLLM, LiteLLM) ---
# Any of these expose an OpenAI-compatible API, so keep LLM_PROVIDER=openai and just point
# OPENAI_BASE_URL at the server. The API key can be any non-empty string (local servers ignore it).
# Use a CAPABLE instruct model (7B+); tiny models can mangle the structured-output labs.
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=ollama
#   OPENAI_MODEL=qwen2.5            # whatever you `ollama pull`ed
# Same machine:   OPENAI_BASE_URL=http://localhost:11434/v1
# Another LAN box: OPENAI_BASE_URL=http://192.168.1.50:11434/v1
#   (the host running Ollama must bind all interfaces: start it with OLLAMA_HOST=0.0.0.0,
#    and allow port 11434 through that machine's firewall.)

# CODEX_MODEL=gpt-5.4
# CODEX_MODEL=gpt-5.4-mini

# CLAUDE_CODE_MODEL=sonnet
# CLAUDE_CODE_MODEL=opus
# CLAUDE_CODE_MODEL=claude-sonnet-4-6

# --- Google Threat Intelligence MCP lab ---
# The MCP server (google/mcp-security, Apache-2.0) is ALREADY INCLUDED in this repo
# at ../mcp-security — no separate clone needed. GTI_MCP_DIR below already points at it.
# To run this lab you still need: (1) `uv` installed (https://docs.astral.sh/uv/),
# and (2) a free VirusTotal API key (https://www.virustotal.com/gui/my-apikey).
VT_APIKEY=paste-your-virustotal-api-key-here
GTI_MCP_COMMAND=uv
GTI_MCP_DIR=../mcp-security/server/gti/gti_mcp

# Lab 03 (Context Window) memory knobs. Trigger = MEMORY_MAX_TOKENS x MEMORY_TRIGGER_RATIO.
# Lower MEMORY_MAX_TOKENS to make compaction fire in fewer turns.
MEMORY_MAX_TOKENS=1000
MEMORY_TRIGGER_RATIO=0.7
MEMORY_PINNED_TURNS=2
MEMORY_KEEP_RECENT=2
